# x86/64 通用配置（虚拟机及物理机）
TARGET="x86/64"
PROFILE="generic"
EXTRA_IMAGE_NAME="x86"
ROOTFS_PARTSIZE="1024"
DAEDE_ARCH="x86_64"
IMAGEBUILDER_URL="https://downloads.immortalwrt.org/releases/25.12-SNAPSHOT/targets/x86/64/immortalwrt-imagebuilder-25.12-SNAPSHOT-x86-64.Linux-x86_64.tar.zst"

# === 要安装的额外包（确认存在于 ImmortalWrt feeds） ===
EXTRA_PACKAGES="luci-theme-argon luci-app-daede kmod-sched-core kmod-sched-bpf kmod-veth kmod-xdp-sockets-diag curl nano nginx openssl-util"

# === 要移除的默认包（确认存在于 feeds，移除安全） ===
REMOVE_PACKAGES="-luci-app-wifihistory -luci-app-advancedplus -luci-app-filemanager -luci-app-wizard -coremark -ds-lite"

# === 第三方包（不在 feeds 里，通过 URL 下载 .apk 文件） ===
