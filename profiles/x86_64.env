# x86/64 通用配置（虚拟机及物理机）
TARGET="x86/64"
PROFILE="generic"
EXTRA_IMAGE_NAME="x86"
ROOTFS_PARTSIZE="1024"
DAEDE_ARCH="x86_64"
IMAGEBUILDER_URL="https://downloads.immortalwrt.org/releases/25.12-SNAPSHOT/targets/x86/64/immortalwrt-imagebuilder-25.12-SNAPSHOT-x86-64.Linux-x86_64.tar.zst"
# openssl-util: 确保首次开机自签证书能顺利生成
EXTRA_PACKAGES="luci luci-i18n-base-zh-cn luci-i18n-package-manager-zh-cn luci-theme-alpha luci-theme-argon luci-app-daede kmod-sched-core kmod-sched-bpf kmod-veth kmod-xdp-sockets-diag curl nano nginx openssl-util -luci-app-wifihistory -luci-app-advancedplus -luci-app-filemanager -luci-app-wizard -coremark -ds-lite"
