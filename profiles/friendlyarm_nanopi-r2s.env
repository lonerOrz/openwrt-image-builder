# NanoPi R2S 设备配置
TARGET="rockchip/armv8"
PROFILE="friendlyarm_nanopi-r2s"
EXTRA_IMAGE_NAME="r2s"
ROOTFS_PARTSIZE="512"
DAEDE_ARCH="aarch64"
IMAGEBUILDER_URL="https://downloads.immortalwrt.org/releases/25.12-SNAPSHOT/targets/rockchip/armv8/immortalwrt-imagebuilder-25.12-SNAPSHOT-rockchip-armv8.Linux-x86_64.tar.zst"

# === 要安装的额外包（确认存在于 ImmortalWrt feeds） ===
# luci-theme-argon: 深色主题
# luci-app-daede: dae/daed 代理客户端
# kmod-sched-core: dae/daed 依赖的流量调度内核模块
# nginx: HTTPS 反向代理
# openssl-util: 首次开机自签证书生成
EXTRA_PACKAGES="luci-theme-argon luci-app-daede kmod-sched-core curl nano nginx openssl-util"

# === 要移除的默认包（确认存在于 feeds，移除安全） ===
# -luci-app-attendedsysupgrade: R2S 用户多为手动刷写，此守护进程占内存
# -luci-app-wifihistory/-advancedplus/-filemanager/-wizard: 冗余 LuCI 应用
# -coremark: 基准测试工具，非生产必需
# -ds-lite/-usb-modeswitch: 国内极少使用
REMOVE_PACKAGES="-luci-app-wifihistory -luci-app-advancedplus -luci-app-filemanager -luci-app-wizard -coremark -ds-lite -usb-modeswitch -luci-app-attendedsysupgrade"

# === 第三方包（不在 feeds 里，通过 URL 下载 .apk 文件） ===
# 格式: 包名=下载URL，每行一个
# 构建脚本会自动下载并放入 ImageBuilder 的 packages 目录
# CUSTOM_PACKAGES="
# luci-theme-alpha=https://github.com/derisamedia/luci-theme-alpha/releases/download/3.9.7-beta2/luci-theme-alpha_3.9.7-beta2-r1_all.apk
# "
