{
  "type": "object",
  "required": ["target", "profile", "extra_image_name", "rootfs_partsize", "imagebuilder_url", "packages"],
  "properties": {
    "target": { "type": "string" },
    "profile": { "type": "string" },
    "extra_image_name": { "type": "string" },
    "rootfs_partsize": { "type": "integer" },
    "imagebuilder_url": { "type": "string" },
    "daede_arch": { "type": "string" },
    "system": {
      "type": "object",
      "required": ["lan_ip", "root_password"],
      "properties": {
        "lan_ip": { "type": "string" },
        "root_password": { "type": "string" },
        "ssl_cn": { "type": "string" }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "lan_ip": { "type": "string" },
        "root_password": { "type": "string" },
        "ssl_cn": { "type": "string" },
        "enable_pppoe": { "type": "boolean" },
        "pppoe_account": { "type": "string" },
        "pppoe_password": { "type": "string" }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "include_docker": { "type": "boolean" },
        "enable_store": { "type": "boolean" },
        "enable_firewall_wan_accept": { "type": "boolean" },
        "packages": {
          "type": "object",
          "description": "功能对应的包列表，启用时自动追加",
          "properties": {
            "docker": { "type": "array", "items": { "type": "string" } },
            "store": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "packages": {
      "type": "object",
      "required": ["add", "remove"],
      "properties": {
        "add": { "type": "array", "items": { "type": "string" } },
        "remove": { "type": "array", "items": { "type": "string" } }
      }
    },
    "custom_apks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source_type"],
        "properties": {
          "name": { "type": "string" },
          "source_type": { "type": "string", "enum": ["github_release", "direct_url"] },
          "repo": { "type": "string" },
          "tag": { "type": "string" },
          "arch": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  }
}
