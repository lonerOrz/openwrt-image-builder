{
  "target": "rockchip/armv8",
  "profile": "friendlyarm_nanopi-r2s",
  "extra_image_name": "r2s",
  "rootfs_partsize": 512,
  "daede_arch": "aarch64_cortex-a53",
  "imagebuilder_url": "https://downloads.immortalwrt.org/releases/25.12-SNAPSHOT/targets/rockchip/armv8/immortalwrt-imagebuilder-25.12-SNAPSHOT-rockchip-armv8.Linux-x86_64.tar.zst",
  "system": {
    "lan_ip": "192.168.100.1",
    "root_password": "password",
    "ssl_cn": "ImmortalWrt"
  },
  "network": {
    "lan_ip": "192.168.100.1",
    "root_password": "password",
    "ssl_cn": "ImmortalWrt",
    "enable_pppoe": false,
    "pppoe_account": "",
    "pppoe_password": ""
  },
  "features": {
    "include_docker": false,
    "enable_store": false,
    "enable_firewall_wan_accept": true,
    "packages": {
      "docker": ["luci-i18n-dockerman-zh-cn"],
      "store": []
    }
  },
  "packages": {
    "add": [
      "luci-theme-argon",
      "kmod-sched-core",
      "curl",
      "nano",
      "nginx",
      "openssl-util"
    ],
    "remove": [
      "luci-app-wifihistory",
      "luci-app-advancedplus",
      "luci-app-filemanager",
      "luci-app-wizard",
      "coremark",
      "ds-lite",
      "usb-modeswitch",
      "luci-app-attendedsysupgrade"
    ]
  },
  "custom_apks": [
    {
      "name": "luci-app-daede",
      "source_type": "github_release",
      "repo": "kenzok8/openwrt-daede",
      "tag": "latest",
      "arch": "aarch64_cortex-a53"
    },
    {
      "name": "luci-app-store",
      "source_type": "git_clone",
      "repo": "wukongdaily/apk",
      "path": "run/arm64-a53"
    }
  ]
}
